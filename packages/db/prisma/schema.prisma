generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth (NextAuth) ----------

enum UserRole {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(USER)

  // Согласия (152-ФЗ)
  privacyAcceptedAt      DateTime?
  personalDataAcceptedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts       Account[]
  sessions       Session[]
  subscription   Subscription?
  transcriptions Transcription[]
  payments       Payment[]
  apiKeys        ApiKey[]
  usageRecords   UsageRecord[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Subscriptions & Billing ----------

enum PlanType {
  FREE
  PRO
  BUSINESS
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
}

enum BillingInterval {
  MONTH
  YEAR
}

model Subscription {
  id     String   @id @default(cuid())
  userId String   @unique
  plan   PlanType @default(FREE)
  status SubscriptionStatus @default(ACTIVE)

  interval          BillingInterval @default(MONTH)
  periodStart       DateTime        @default(now())
  periodEnd         DateTime?
  cancelAtPeriodEnd Boolean         @default(false)

  yookassaPaymentMethodId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  CANCELED
  REFUNDED
}

model Payment {
  id          String        @id @default(cuid())
  userId      String
  amount      Decimal       @db.Decimal(10, 2)
  currency    String        @default("RUB")
  status      PaymentStatus @default(PENDING)
  description String?
  yookassaId  String?       @unique
  plan        PlanType?
  interval    BillingInterval?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------- Transcriptions ----------

enum TranscriptionStatus {
  PENDING
  DOWNLOADING
  PROCESSING
  COMPLETED
  FAILED
}

enum TranscriptionSource {
  UPLOAD
  URL
}

model Transcription {
  id     String              @id @default(cuid())
  userId String
  title  String
  source TranscriptionSource
  status TranscriptionStatus @default(PENDING)

  sourceUrl   String? // для source = URL
  fileKey     String? // ключ в S3 для source = UPLOAD
  mimeType    String?
  fileSize    Int?
  durationSec Float?
  language    String? // ISO 639-1 или "auto"
  progress    Int     @default(0) // 0-100

  text     String? @db.Text
  segments Json? // [{ start, end, text }]
  error    String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
}

// Учёт использованных минут по периодам (для лимитов тарифа)
model UsageRecord {
  id          String   @id @default(cuid())
  userId      String
  periodStart DateTime
  periodEnd   DateTime
  secondsUsed Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periodStart])
  @@index([userId])
}

// ---------- API (Business план) ----------

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  prefix     String // первые символы ключа для отображения
  keyHash    String    @unique
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
